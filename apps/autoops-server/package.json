{
  "name": "@autoops/server",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "@alicloud/pop-core": "^1.8.0",
    "@fastify/autoload": "^6.3.1",
    "@fastify/multipart": "^9.2.1",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/adapter-mariadb": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/node-cron": "^3.0.11",
    "acme-client": "^5.4.0",
    "alidns": "^0.0.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.1",
    "fastify-cli": "^7.4.1",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "c8": "^11.0.0",
    "concurrently": "^9.2.1",
    "fastify-tsconfig": "^3.0.0",
    "prisma": "^7.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "test": "npm run build:ts && tsc -p test/tsconfig.json && c8 node --test --test-force-exit -r ts-node/register \"test/**/*.ts\"",
    "start": "npm run build:ts && fastify start -l info dist/app.js",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "db:init": "npx prisma migrate dev --name init",
    "db:generate": "npx prisma generate",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js",
    "generate:jwt": "node scripts/generate-jwt-secret.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT"
}
